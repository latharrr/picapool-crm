# ── Google Sheets (the database) ────────────────────────────────────────────
# Service account credentials. Create one in Google Cloud Console, enable the
# Sheets API + Drive API, and paste its values here. See docs/SERVICE_ACCOUNT.md.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key exactly as it appears in the downloaded JSON key file,
# keeping the \n escape sequences (do not replace them with real newlines).
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ID of the central "Root" spreadsheet holding Users / Roles_Permissions /
# Workspaces / User_Workspaces. Leave empty for local dev; run
# `npm run provision:root` once you have service account credentials, then
# paste the printed spreadsheet ID here (and into your Vercel project env vars).
ROOT_SPREADSHEET_ID=

# ── KV / cache / locking (Upstash Redis — what "Vercel KV" provisions today) ─
# Leave both empty during local development: the app falls back to an
# in-memory cache automatically (single-process only, not for production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Auth (NextAuth / Auth.js v5) ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Optional: Google OAuth restricted to a workspace domain. Leave empty to
# disable Google sign-in and use email/password (Credentials provider) only.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ALLOWED_GOOGLE_DOMAIN=picapool.com

# ── Cron ─────────────────────────────────────────────────────────────────────
# Shared secret checked against the `Authorization: Bearer <value>` header
# Vercel Cron sends to /api/cron/* routes. Generate with: openssl rand -hex 32
CRON_SECRET=
